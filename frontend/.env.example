# LLM API 설정 (없으면 자동으로 DEMO_MODE 활성화)
LLM_API_KEY=
LLM_MODEL=gpt-4o
LLM_PROVIDER=openai

# 앱 설정
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# 강제 데모 모드 (API 키가 있어도 mock 응답 사용)
DEMO_MODE=false

# 인증 (JWT)
JWT_SECRET=your_jwt_secret_here_change_in_production

# 관리자 계정
ADMIN_EMAIL=admin@fmd.dev
ADMIN_PASSWORD=your_admin_password_here
